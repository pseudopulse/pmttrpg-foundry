{
  "name": "pmttrpg",
  "version": "2.0.0",
  "description": "CSS compiler for the PMTTRPG system",
  "scripts": {
    "build": "sass src/scss/pmttrpg.scss css/pmttrpg.css --style=expanded --no-source-map",
    "watch": "sass src/scss/pmttrpg.scss css/pmttrpg.css --style=expanded --source-map --watch",
    "createSymlinks": "node ./tools/create-symlinks.mjs"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "pseudopulse",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "sass": "^1.53.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
