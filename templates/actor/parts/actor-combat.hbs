<div class="tab combat" data-group="primary" data-tab="combat">
  <div class="grid-2col">
    {{!-- Emotion --}}
    <div class="ac-resources-holder ac-grid-object" style="width: 17.5rem">
      <div class="ac-resource" style="height: 3.5rem; gap: 4rem; width: 16rem;">
        <img class="ac-resource-icon" style="padding: 0px; margin: 1rem;" src="systems/pmttrpg/assets/resources/EmotionIcon.png" width="24" height="24" />
        <div class="ac-resource-xp">
          <input style="height: 2rem;" onkeypress="unfocus(event)" class="as-resource-input emotion-input" type="text"
            inputmode="numeric" value="{{system.emotion}}"
            data-dtype="Number" />
        </div>
      </div>

      <div class="ac-resource" style="height: 3.5rem; gap: 1.5rem; width: 16rem;">
        <label class="ac-item-name">Disposition:</label>
        <div class="ac-resource-content">
            <button onclick="toggleDP(event)" class="ac-dropbtn ac-small-dropdown" style="width: 8rem;">
                {{system.disposition}}
            </button>
            <div id="dispodrp" class="ac-dropdown-content">
                <a class="dispo-entry">None</a>
                <a class="dispo-entry">Anxious</a>
                <a class="dispo-entry">Focused</a>
                <a class="dispo-entry">Generous</a>
                <a class="dispo-entry">Gloomy</a>
                <a class="dispo-entry">Masochistic</a>
                <a class="dispo-entry">Possessive</a>
                <a class="dispo-entry">Protective</a>
                <a class="dispo-entry">Tenacious</a>
                <a class="dispo-entry">Wrathful</a>
                <a class="dispo-entry">Vengeful</a>
            </div>
        </div>
      </div>

      {{#if (hasAugment actor "Multifaceted")}}
      <div class="ac-resource" style="height: 3.5rem; gap: 1rem; width: 16rem;">
        <label class="ac-item-name">Multifaceted:</label>
        <div class="ac-resource-content">
            <button onclick="toggleDP2(event)" class="ac-dropbtn ac-small-dropdown" style="width: 8rem;">
                {{system.secondaryDisposition}}
            </button>
            <div id="dispodrp2" class="ac-dropdown-content">
                <a class="dispo-entry-2">None</a>
                <a class="dispo-entry-2">Anxious</a>
                <a class="dispo-entry-2">Focused</a>
                <a class="dispo-entry-2">Generous</a>
                <a class="dispo-entry-2">Gloomy</a>
                <a class="dispo-entry-2">Masochistic</a>
                <a class="dispo-entry-2">Possessive</a>
                <a class="dispo-entry-2">Protective</a>
                <a class="dispo-entry-2">Tenacious</a>
                <a class="dispo-entry-2">Wrathful</a>
                <a class="dispo-entry-2">Vengeful</a>
            </div>
        </div>
      </div>
      {{/if}}
    </div>

    {{!-- Statistics --}}
    <div class="ac-resources-holder grid-2col ac-grid-object" style="width: 17.5rem; padding: 3%;">
      <div class="ac-resource ac-stat-holder" title="Temp HP: {{system.attributes.health.temp}}">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/resources/HPIcon.webp" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" name="system.emotion" value="{{system.attributes.health.value}}"
            data-dtype="Number" />
        </div>
      </div>
      <div class="ac-resource ac-stat-holder" title="Temp ST: {{system.attributes.stagger.temp}}">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/resources/StaggerIcon.webp" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" name="system.emotion" value="{{system.attributes.stagger.value}}"
            data-dtype="Number" />
        </div>
      </div>
      <div class="ac-resource ac-stat-holder" title="Temp SP: {{system.attributes.sanity.temp}}">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/resources/PanicBlue.png" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" name="system.emotion" value="{{system.attributes.sanity.value}}"
            data-dtype="Number" />
        </div>
      </div>
      <div class="ac-resource ac-stat-holder">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/resources/LightIcon.webp" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" name="system.emotion" value="{{system.attributes.light.value}}"
            data-dtype="Number" />
        </div>
      </div>
    </div>

    {{!- Tracker Panel }}
    <div class="ac-resources-holder ac-grid-object" style="width: 35.8rem; height: 4.5rem; grid-template-columns: repeat(4, 1fr); grid-column: 1 / -1 !important; padding: 0px; justify-items: center">
      <div class="ac-resource ac-stat-holder" title="Clashes Won">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/resources/ClashPowerUp.png" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" value="{{system.clashesWon}}"
            data-dtype="Number" />
        </div>
      </div>
      <div class="ac-resource ac-stat-holder" title="Clashes Lost">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/resources/ClashPowerDown.png" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" value="{{system.clashesLost}}"
            data-dtype="Number" />
        </div>
      </div>
      {{#if system.overchargeDeclared}}
      <div class="ac-resource ac-stat-holder" title="Charge Spent">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/status/Charge.png" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" value="{{system.chargeSpent}}"
            data-dtype="Number" />
        </div>
      </div>
      {{else}}
      <div class="ac-resource ac-stat-holder" title="Declare Overcharge">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/status/Overcharge.png" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-ocDeclare" type="checkbox" />
        </div>
      </div>
      {{/if}}
      <div class="ac-resource ac-stat-holder" title="Consumed Bloodfeast">
        <img class="ac-resource-icon ac-stat-icon"  src="systems/pmttrpg/assets/resources/Bloodfeast.png" width="24" height="24" />
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" value="{{system.bloodfeastConsumed}}"
            data-dtype="Number" />
        </div>
      </div>
    </div>

    {{!- Damage Panel }}
    <div class="ac-resources-holder ac-grid-object ac-damage-panel" style="width: 35.8rem; height: 4.5rem; grid-template-columns: repeat(2, 1fr); grid-column: 1 / -1 !important;">
      <div class="ac-resource ac-stat-holder ac-damage-stat" title="Total Damage Dealt" style="gap: 1rem !important;">
        <label class="ac-item-name">Damage Dealt:</label>
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" value="{{system.damageDealt}}"
            data-dtype="Number" style="width: 7rem;" />
        </div>
      </div>
      <div class="ac-resource ac-stat-holder ac-damage-stat" title="Total Damage Taken" style="gap: 1rem !important;">
        <label class="ac-item-name">Damage Taken:</label>
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input ac-nop" type="text"
            inputmode="numeric" value="{{system.damageTaken}}"
            data-dtype="Number" style="width: 7rem;" />
        </div>
      </div>
    </div>

    {{!- Actions Panel }}
    <div class="ac-resources-holder ac-grid-object ac-damage-panel" style="width: 35.8rem; height: 4.5rem; grid-template-columns: repeat(2, 1fr); grid-column: 1 / -1 !important;">
      <div class="ac-resource ac-stat-holder ac-damage-stat" title="Actions Remaining" style="gap: 1rem !important;">
        <label class="ac-item-name">Actions:</label>
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input" type="text"
            inputmode="numeric" value="{{system.actions}}"
            data-dtype="Number" style="width: 7rem;" />
        </div>
      </div>
      <div class="ac-resource ac-stat-holder ac-damage-stat" title="Reactions Remaining" style="gap: 1rem !important;">
        <label class="ac-item-name">Reactions:</label>
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input" type="text"
            inputmode="numeric" value="{{system.reactions}}"
            data-dtype="Number" style="width: 7rem;" />
        </div>
      </div>
      <div class="ac-resource ac-stat-holder ac-damage-stat" title="Reactions Remaining" style="gap: 1rem !important;">
        <label class="ac-item-name">Movement:</label>
        <div class="ac-resource-xp">
          <input onclick="setCursorRight()"  onkeypress="unfocus(event)" class="ac-stat-text as-resource-input" type="text"
            inputmode="numeric" value="{{system.movement}}"
            data-dtype="Number" style="width: 7rem;" />
        </div>
      </div>
    </div>

    {{#if hasOutgoingMarks}}
    <div class="ac-resources-holder ac-grid-object ac-marks" style="width: 35.8rem; height: 7.5rem; grid-template-columns: repeat(4, 1fr); grid-column: 1 / -1 !important; padding: 0px; justify-items: center">
      {{#each outgoingMarks as |mark mark|}}
      <div class="ac-resource ac-stat-holder ac-mark-holder" data-id="{{mark.id}}" data-target="{{mark.target.id}}">
        <div class="ac-mark-block">
          <h class="" style="text-align: center">{{mark.name}}</h>
          <div style="display: flex; gap: 1rem;">
            <p class="" style="text-align: left; text-wrap-mode: nowrap;">Applied to: <br>{{mark.target.name}}</p>
            <button class="ac-mark-remove" title="Remove Mark">X</button>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{#if hasIncomingMarks}}
    <div class="ac-resources-holder ac-grid-object ac-marks" style="width: 35.8rem; height: 7.5rem; grid-template-columns: repeat(4, 1fr); grid-column: 1 / -1 !important; padding: 0px; justify-items: center">
      {{#each incomingMarks as |mark mark|}}
      <div class="ac-resource ac-stat-holder ac-mark-holder" data-id="{{mark.id}}" data-target="{{mark.target.id}}">
        <div class="ac-mark-block">
          <h class="" style="text-align: center">{{mark.name}}</h>
          <p class="" style="text-align: center; text-wrap-mode: nowrap;">Applied by: <br>{{mark.source.name}}</p>
        </div>
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{#if (recycleable actor)}}
    {{!- Recycle Panel }}
    <div class="ac-resources-holder ac-grid-object ac-recycle-panel ac-marks" style="width: 35.8rem; height: 10rem; grid-template-columns: repeat(2, 1fr); grid-column: 1 / -1 !important;">
      {{#with (getRecycleContext system.recycleAction) as |action|}}
        <div class="ac-resource" style="width: 9rem; height: 100%; justify-content: center; flex-direction: column; gap: 0rem;">
          <div style="display: flex; gap: 0.3rem; font-size: 18px;">
            <p class="wb-rollDisplay">{{action.context.diceCount}}d{{action.context.diceMax}}+{{action.context.dicePower}}</p>
            <p> / </p>
            <p>{{action.context.result}}</p>
          </div>
          <div style="display: flex;">
            <img class="ac-resource-icon" 
                    src='systems/pmttrpg/assets/damageTypes/{{action.type}}.png' width='24' height='24' style="width: 3.5rem; height: 3.5rem; margin: 0 0 0 0.5rem; padding: 6%;"/>
                <label class="resource-label" style="text-align: center; align-self: center">Recycled {{action.type}}</label>
          </div>
        </div>
        <div class="ac-resource ac-clashDescription" style="width: 25rem">
          {{{action.description}}}
        </div>
      {{/with}}
    </div>
    {{/if}}
  </div>
</div>

<script>
    function toggleDP(event) {
      console.log("dp");
      console.log(event.currentTarget);
      event.preventDefault();
      document.getElementById('dispodrp').classList.toggle("ac-show");
    }

    function toggleDP2(event) {
      console.log("dp2");
      console.log(event.currentTarget);
      event.preventDefault();
      document.getElementById('dispodrp2').classList.toggle("ac-show");
    }

    function preventDefault(event) {
      event.preventDefault();
    }

    function filterFunction(element1, element2) {
        let input = document.getElementById(element1);
        let filter = input.value.toUpperCase();
        let div = document.getElementById(element2);
        let a = div.getElementsByTagName("a");

        for (let i = 0; i < a.length; i++) {
            let txtValue = a[i].textContent || a[i].innerText;
            a[i].style.display =
                txtValue.toUpperCase().indexOf(filter) > -1 ? "" : "none";
        }
    }
</script>

