<ol class='items-list'>
  <li class='item flexrow items-header'>
    <div class='item-controls'>
      <a class='item-control item-create' title='Create Weapon' data-type='weapon'>
        <i class='fas fa-plus'></i>
        New Weapon
      </a>
    </div>
  </li>
  {{#each weapons as |item id|}}
  <li class='item flexrow' data-item-id='{{item._id}}'>
    <div class="aw-resource">
      <div class='aw-item-name'>
        <div class='aw-item-icon'>
          <a class='rollable' data-roll-type='item'>
            <img class="aw-type-img" src='systems/pmttrpg/assets/damageTypes/{{item.system.damageType}}.png' title='Roll Attack'
              width='24' height='24' />
          </a>
        </div>
        <h4 class="aw-item-text">{{item.name}}</h4>
      </div>
      <div>
        {{#with (rctx item) as |rollContext|}}
          <h4 class="aw-item-text">{{rollContext.diceCount}}d{{rollContext.diceMax}}+{{rollContext.dicePower}}</h4>
        {{/with}}
      </div>
      <div class='item-controls aw-controls'>
        <a class='item-control item-edit' title='{{localize "DOCUMENT.Update" type=' Item'}}'>
          <i class='fas fa-edit aw-font-button'></i>
        </a>
        <a class='item-control item-delete' title='{{localize "DOCUMENT.Delete" type=' Item'}}'>
          <i class='fas fa-trash aw-font-button'></i>
        </a>
      </div>
    </div>
  </li>
  {{/each}}
</ol>

