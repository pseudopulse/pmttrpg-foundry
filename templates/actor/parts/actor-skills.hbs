<ol class='items-list'>
    <li class='item flexrow items-header'>
        <div class='item-controls'>
            <a class='item-control item-create' title='Create Skill' data-type='skill'>
                <i class='fas fa-plus'></i>
                New Skill
            </a>
        </div>
    </li>
    {{#each skills as |item id|}}
    <li class='item flexrow' data-item-id='{{item._id}}'>
        <div class="ak-resource">
            <div class="ak-roll-info">
                <div class='ak-item-icon'>
                    <a class='rollable' data-roll-type='item'>
                        <img class="ak-type-img" src='systems/pmttrpg/assets/damageTypes/{{item.system.type}}.png' title='Roll Attack'
                            width='24' height='24' />
                    </a>
                </div>
            </div>
            <div class='ak-item-name'>
                <h4 class="ak-item-text">{{item.name}}</h4>
            </div>
            {{> ptSkillCosts item context=(rctx item)}}
            <div class='item-controls ak-controls'>
                <a class='item-control item-edit' title='{{localize "DOCUMENT.Update" type=' Item'}}'>
                    <i class='fas fa-edit ak-font-button'></i>
                </a>
                <a class='item-control item-delete' title='{{localize "DOCUMENT.Delete" type=' Item'}}'>
                    <i class='fas fa-trash ak-font-button'></i>
                </a>
            </div>
        </div>
    </li>
    {{/each}}
</ol>

