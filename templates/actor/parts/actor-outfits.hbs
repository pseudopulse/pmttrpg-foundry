<ol class='items-list'>
    <li class='item flexrow items-header'>
        <div class='item-controls'>
            <a class='item-control item-create' title='Create Outfit' data-type='outfit'>
                <i class='fas fa-plus'></i>
                New Outfit
            </a>
        </div>
    </li>
    {{#each outfits as |item id|}}
    <li class='item flexrow' data-item-id='{{item._id}}'>
        <div class="ao-resource">
            <div class='ao-item-name'>
                <h4 class="ao-item-text">{{item.name}}</h4>
            </div>
            <div class="ao-roll-info">
                <div class='ao-item-icon'>
                    <a class='rollable' data-roll-type='item'>
                        <img class="ao-type-img" src='systems/pmttrpg/assets/damageTypes/Block.png' title='Roll Attack'
                            width='24' height='24' />
                    </a>
                </div>

                {{#with (drctx item "Block") as |rollContext|}}
                <h4 class="ao-item-text">{{rollContext.diceCount}}d{{rollContext.diceMax}}+{{rollContext.dicePower}}
                </h4>
                {{/with}}
            </div>
            <div class="ao-roll-info">
                <div class='ao-item-icon'>
                    <a class='rollable' data-roll-type='item'>
                        <img class="ao-type-img" src='systems/pmttrpg/assets/damageTypes/Evade.png' title='Roll Attack'
                            width='24' height='24' />
                    </a>
                </div>

                {{#with (drctx item "Evade") as |rollContext|}}
                <h4 class="ao-item-text">{{rollContext.diceCount}}d{{rollContext.diceMax}}+{{rollContext.dicePower}}
                </h4>
                {{/with}}
            </div>
            <div class='item-controls ao-controls'>
                <a class='item-control item-edit' title='{{localize "DOCUMENT.Update" type=' Item'}}'>
                    <i class='fas fa-edit ao-font-button'></i>
                </a>
                <a class='item-control item-delete' title='{{localize "DOCUMENT.Delete" type=' Item'}}'>
                    <i class='fas fa-trash ao-font-button'></i>
                </a>
            </div>
        </div>
    </li>
    {{/each}}
</ol>

