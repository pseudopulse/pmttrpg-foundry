<ol class='items-list'>
  <li class='item flexrow items-header'>
    <div class='item-controls'>
      <a style="text-wrap-mode: nowrap;" class='item-control item-create' title='Create Augment' data-type='augment'>
        <i class='fas fa-plus'></i>
        New Augment
      </a>
    </div>
  </li>
  {{#each augments as |item id|}}
  <li class='item flexrow' data-item-id='{{item._id}}'>
    <div class="aa-resource">
      <div class='aa-item-name'>
        <h4 class="aa-item-text">{{item.name}}</h4>
      </div>
      <div>
      <div class='item-controls aa-controls'>
        <a class='item-control item-edit' title='{{localize "DOCUMENT.Update" type=' Item'}}'>
          <i class='fas fa-edit aa-font-button'></i>
        </a>
        <a class='item-control item-delete' title='{{localize "DOCUMENT.Delete" type=' Item'}}'>
          <i class='fas fa-trash aa-font-button'></i>
        </a>
      </div>
    </div>
  </li>
  {{/each}}
</ol>

