<form class="{{cssClass}} flexcol" autocomplete="off">
    <section class="sheet-body">
        <div class="als-resources-holder">
            <div class="als-resource als-prompt-text" style="
                display: flex;
                flex-direction: column;
                gap: 0rem !important;
            ">
                {{{prompt}}}
            </div>

            <div class="als-holder" style="position: relative">
                {{#each allies as |ally|}}
                    <div class="als-allyCard" data-id="{{ally.id}}">
                        <h4 class="als-allyName">{{ally.name}}</h4>
                        <input type="number" max="0" min="0" class="als-numInput"/>
                    </div>
                {{/each}}
            </div>
        </div>
    </section>
</form>

<script>
    function setCursorRight() {
        const input = document.activeElement;
        const length = input.value.length;
        input.setSelectionRange(length, length);
    }

    function unfocus(event) {
        if (event.key == "Enter") {
            const input = document.activeElement;
            input.blur()
        }
    }
</script>

