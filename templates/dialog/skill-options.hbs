<form class="flexcol sto-form" autocomplete="off" data-actor-id="{{actor._id}}">
    <section class="sheet-body resource-container flexcol">
        <div>
            <div class="sto-resources-holder">
                <div class="sto-resource" style="height: 3.5rem; gap: 1.5rem; width: 100%;">
                    <label class="sto-item-name">Targeting:</label>
                    <div class="sto-resource-content">
                        <button onclick="toggleAT('sto-targetDrp')" class="sts-dropbtn sts-small-dropdown" style="width: 12rem;" id="sto-targetButton">
                            {{target}}
                        </button>
                        <div id="sto-targetDrp" class="sts-dropdown-content" style="width: 12rem; text-align: center;">
                            {{#each targets as |target|}}
                                <a onclick="toggleAT('sto-targetDrp')" class="sto-target-entry" data-id="{{target.id}}">{{target.name}}</a>
                            {{/each}}
                        </div>
                    </div>
                </div>
            </div>

            <div class="sto-resources-holder">
                <div class="sto-block-holder">
                    <div id="sts-skills">
                        {{#each skills as |item id|}}
                        <li class='item flexrow' data-item-id='{{item._id}}'>
                            <div class="sts-resource">
                                <div class='sts-item-name'>
                                    <div class='sts-item-icon'>
                                        <a class='rollable' data-roll-type='item'>
                                            <img class="sts-type-img"
                                                src='systems/pmttrpg/assets/damageTypes/Action.png'
                                                title='Attack' width='24' height='24' />
                                        </a>
                                    </div>
                                    <h4 class="sts-item-text">{{item.name}}</h4>
                                </div>
                                {{> ptSkillCosts item context=(rctx item)}}
                            </div>
                        </li>
                        {{/each}}
                    </div>
                </div>
            </div>
        </div>
        <div>
    </section>
</form>

<script>
    function setCursorRight() {
        const input = document.activeElement;
        const length = input.value.length;
        input.setSelectionRange(length, length);
    }

    function unfocus(event) {
        if (event.key == "Enter") {
            const input = document.activeElement;
            input.blur()
        }
    }

    function toggleAT(element) {
        document.getElementById(element).classList.toggle("sts-show");
    }
</script>

