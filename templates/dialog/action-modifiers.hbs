<form class="flexcol am-form" autocomplete="off" data-actor-id="{{actor._id}}">
    <section class="sheet-body resource-container flexcol">
        <div class="am-options-holder">
            <div class="amw-resource am-option">
                <div class='amw-item-name am-option-text' title="CW/CL effects will not trigger for this clash.">
                    <input class="amw-skill-input misc-toggle" type="checkbox" data-id="IgnoreCWL" />
                    <h4 class="amw-item-text am-option-text">Ignore Clash Effects</h4>
                </div>
            </div>
            <div class="amw-resource am-option">
                <div class='amw-item-name am-option-text' title="Roll with advantage.">
                    <input class="amw-skill-input misc-toggle" type="checkbox" data-id="Adv" />
                    <h4 class="amw-item-text am-option-text">Advantage</h4>
                </div>
            </div>
            <div class="amw-resource am-option">
                <div class='amw-item-name am-option-text' title="Roll with disadvantage.">
                    <input class="amw-skill-input misc-toggle" type="checkbox" data-id="Disadv" />
                    <h4 class="amw-item-text am-option-text">Disadvantage</h4>
                </div>
            </div>
        </div>
        <div class="am-resources-holder">
            <nav class="am-resource am-tab-bar" data-group="primary">
                <a class="item amw-tab-button">Skills</a>
                <a class="item amw-tab-button">Tools</a>
                <a class="item amw-tab-button">Conditionals</a>
            </nav>
            <div class="am-block-holder">
                <div id="amw-skills">
                    {{#each skills as |item id|}}
                    <li class='item flexrow' data-item-id='{{item._id}}'>
                        {{#with (rctx item) as |ctx|}}
                            {{#if (checkCosts ../../actor ctx.costs ctx.item.light)}}
                            <div class="amw-resource">
                                <div class='amw-item-name'>
                                    <input class="amw-skill-input skill-toggle" type="checkbox" />
                                    <h4 class="amw-item-text">{{ctx.item.name}}</h4>
                                </div>
                                {{> ptSkillCosts ctx.item context=ctx}}
                            </div>
                            {{else}}
                            <div class="amw-resource am-disabled">
                                <div class='amw-item-name'>
                                    <input class="amw-skill-input skill-toggle" type="checkbox" />
                                    <h4 class="amw-item-text">{{ctx.item.name}}</h4>
                                </div>
                                {{> ptSkillCosts ctx.item context=ctx}}
                                <h4 class="amw-item-text am-disabled-text">Can't Afford!</h4>
                            </div>
                            {{/if}}
                        {{/with}}
                    </li>
                    {{/each}}
                </div>

                <div id="amw-tools">

                </div>

                <div id="amw-conditionals">
                    {{#each conditionals as |item|}}
                    <li class='item flexrow' data-item-id='{{item.name}}'>
                        {{#if (checkCosts ../actor item.costs 0)}}
                        <div class="amw-resource">
                            <div class='amw-item-name' title="{{item.description}}">
                                <input class="amw-skill-input conditional-toggle" type="checkbox" />
                                <h4 class="amw-item-text">{{item.name}}</h4>
                            </div>
                            {{> ptConditionalCosts cost=item.costs}}
                        </div>
                        {{else}}
                        <div class="amw-resource am-disabled">
                            <div class='amw-item-name am-disabled' title="{{item.description}}">
                                <input class="amw-skill-input conditional-toggle" type="checkbox" />
                                <h4 class="amw-item-text">{{item.name}}</h4>
                            </div>
                            {{> ptConditionalCosts cost=item.costs}}
                            <h4 class="amw-item-text am-disabled-text">Can't Afford!</h4>
                        </div>
                        {{/if}}
                    </li>
                    {{/each}}
                </div>
            </div>
        </div>
    </section>
</form>

<script>
    function setCursorRight() {
        const input = document.activeElement;
        const length = input.value.length;
        input.setSelectionRange(length, length);
    }

    function unfocus(event) {
        if (event.key == "Enter") {
            const input = document.activeElement;
            input.blur()
        }
    }
</script>

