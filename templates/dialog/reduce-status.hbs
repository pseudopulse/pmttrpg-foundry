    }

    .rs-resource-content {
        display: flexbox;
        justify-content: center;
        align-items: center;
        flex-direction: row;
        grid: 1 / span 3;
        gap: 0;
        margin: auto;
    }

    .rs-resource-divider {
        text-align: center;
    }

    .rs-resource-icon {
        width: 50px;
        height: 50px;
        border: none;
        margin: auto;
