<form class="{{cssClass}} flexcol" autocomplete="off">
    <section class="sheet-body">
        <div class="rs-resources-holder">
            <div class="rs-resource rs-prompt-text" style="
                display: flex;
                flex-direction: column;
                gap: 0rem !important;
            ">
                <h4>{{source}}</h4>
                <h4>Select up to {{count}} status effect stacks to reduce!</h4>
            </div>

            <div id="rs-standardStatus" style="position: relative">
                <div class="rs-holder">
                    <div class="rs-status">
                        <img src="systems/pmttrpg/assets/status/Burn.png" class="rs-statusIcon" title="Burn" />
                        <div class="rs-statusInputHolder" data-status="Burn">
                            <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="rs-statusInput"
                                type="number"
                                value="0" data-dtype="Number" title="Reduction Amount" />
                        </div>
                    </div>
                    <div class="rs-status">
                        <img src="systems/pmttrpg/assets/status/Frostbite.png" class="rs-statusIcon" title="Frostbite" />
                        <div class="rs-statusInputHolder" data-status="Frostbite">
                            <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="rs-statusInput"
                                type="number"
                                value="0" data-dtype="Number" title="Reduction Amount" />
                        </div>
                    </div>
                    <div class="rs-status">
                        <img src="systems/pmttrpg/assets/status/Smoke.png" class="rs-statusIcon" title="Smoke" />
                        <div class="rs-statusInputHolder" data-status="Smoke">
                            <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="rs-statusInput"
                                type="number"
                                value="0" data-dtype="Number" title="Reduction Amount" />
                        </div>
                    </div>
                    <div class="rs-status">
                        <img src="systems/pmttrpg/assets/status/Bleed.png" class="rs-statusIcon" title="Bleed" />
                        <div class="rs-statusInputHolder" data-status="Bleed">
                            <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="rs-statusInput"
                                type="number"
                                value="0" data-dtype="Number" title="Reduction Amount" />
                        </div>
                    </div>
                </div>
                <div id="rs-standardStatusBox" class="rs-disabled"></div>
            </div>

            <div id="rs-pauseStatus" style="position: relative">
                <div class="rs-holder">
                    <div class="rs-status">
                        <img src="systems/pmttrpg/assets/status/Hemorrhage.png" class="rs-statusIcon" title="Hemorrhage" />
                        <div class="rs-statusInputHolder" data-status="Hemorrhage">
                            <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="rs-statusInput"
                                type="number"
                                value="0" data-dtype="Number" title="Reduction Amount" />
                        </div>
                    </div>
                    <div class="rs-status">
                        <img src="systems/pmttrpg/assets/status/Renewed_Blaze.png" class="rs-statusIcon" title="Renewed Blaze" />
                        <div class="rs-statusInputHolder" data-status="Renewed_Blaze">
                            <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="rs-statusInput"
                                type="number"
                                value="0" data-dtype="Number" title="Reduction Amount" />
                        </div>
                    </div>
                    <div class="rs-status">
                        <img src="systems/pmttrpg/assets/status/Deep_Chill.png" class="rs-statusIcon" title="Deep Chill" />
                        <div class="rs-statusInputHolder" data-status="Deep_Chill">
                            <input onclick="setCursorRight()" onkeypress="unfocus(event)" class="rs-statusInput"
                                type="number"
                                value="0" data-dtype="Number" title="Reduction Amount" />
                        </div>
                    </div>
                </div>
                <div id="rs-pauseStatusBox" class="rs-disabled"></div>
            </div>
        </div>
    </section>
</form>

<script>
    function setCursorRight() {
        const input = document.activeElement;
        const length = input.value.length;
        input.setSelectionRange(length, length);
    }

    function unfocus(event) {
        if (event.key == "Enter") {
            const input = document.activeElement;
            input.blur()
        }
    }
</script>

<style>
    .rs-statusInputHolder {

    }

    .rs-disabled {
        pointer-events: none !important;
