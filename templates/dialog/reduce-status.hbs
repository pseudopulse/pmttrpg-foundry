    }

    .rs-text-field {
        width: 15rem;
        text-align: center;
    }

    .rs-prompt-text {
        font-size: 16px;
        font-weight: bold;
    }

    .rs-resources-holder {
        background-color: #1d1b22;
        border: 2px solid slategray;
        padding: 2%;
