<form class="{{cssClass}} flexcol" autocomplete="off">
    <section class="sheet-body">
        <div class="id-resources-holder">
            <div class="id-resource id-prompt-text">
                <h4>{{{prompt}}}</h4>
            </div>
            <div class="id-resource">
                <button onclick="toggleID('toggle-idrp')" class="id-dropbtn id-small-dropdown" id="idrp-button">
                    <img src="systems/pmttrpg/assets/null" width="48" height="48" class="id-drp-img"/>
                    <a class="id-drp-option">placeholder</a>
                </button>
                <div class="id-dropdown-content id-drp-input" id="toggle-idrp">
                    {{#each options as |option|}}
                    <div class="id-drp-selection" onclick="toggleID('toggle-idrp')">
                        {{#if (ne options.icon null)}}
                        <img src="systems/pmttrpg/assets/{{option.icon}}" width="48" height="48" class="id-drp-img"/>
                        {{/if}}
                        <a class="id-drp-option">{{option.name}}</a>
                    </div>
                    {{/each}}
                </div>
        </div>
            </div>
        </div>
    </section>
</form>

<script>
    function setCursorRight() {
        const input = document.activeElement;
        const length = input.value.length;
        input.setSelectionRange(length, length);
    }

    function toggleID(element) {
        document.getElementById(element).classList.toggle("id-show");
    }


    function unfocus(event) {
        if (event.key == "Enter") {
            const input = document.activeElement;
            input.blur()
        }
    }
</script>

<style>
    .id-clashDescription {
        overflow-y: scroll;
        width: 100%;
        padding: 0 2% !important;
        text-wrap-mode: wrap;
    }

    .id-statblock-container {
        padding: 2% !important;
        columns: 2;
        display: flex;
        gap: 0.5rem;
    }

    .id-rollInfo {
        height: 9rem;
        width: 8rem;
        padding: 2% !important;
    }

    .id-drp-selection {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        width: fit-content;
    }

    .id-drp-img {
        border: none;
        width: 2rem;
        height: 2rem;
    }

    .id-resource {
        background-color: cadetblue;
        border: 2px solid black;
        border-radius: 1px;
        display: grid;
        grid-template-columns: auto 1fr;
        align-items: center;
        gap: 0.5rem;
        padding: 5%;
        position: relative;
    }

    .id-resource-input {
        background-color: slategray;
        border: 1px solid silver;
        text-align: center;
        width: 4rem;
    }

    .id-nop {
        pointer-events: none;
    }

    .id-resource-content {
        display: flexbox;
        justify-content: center;
        align-items: center;
        flex-direction: row;
        grid: 1 / span 3;
        gap: 0;
        margin: auto;
    }

    .id-resource-divider {
        text-align: center;
    }

    .id-resource-icon {
        width: 50px;
        height: 50px;
        border: none;
        margin: auto;
        padding: 10%;
    }

    .id-text-field {
        width: 15rem;
        text-align: center;
    }

    .id-prompt-text {
        font-size: 16px;
        font-weight: bold;
    }

    .id-resources-holder {
        background-color: #1d1b22;
        border: 2px solid slategray;
        padding: 2%;
        width: 100%;
        height: 15rem;
        gap: 0.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .id-padding-t2 {
        padding-top: 2%;
        padding-bottom: 2%;
    }

    .id-padding-0 {
        padding: 0;
    }

    .id-dropbtn {
        background-color: cadetblue;
        color: white;
        padding: 16px;
        font-size: 16px;
        border: none;
        cursor: pointer;
        text-align: center;
        justify-content: center;
        width: 9rem;
        height: 2rem;
        line-height: 0;
        text-wrap-mode: nowrap;
        display: flex;
    }

    .id-dropbtn-small {
        width: 3rem;
        height: 2rem;
        line-height: 0;
    }

    .id-dropbtn:hover,
    .id-dropbtn:focus {
        background-color: slategray;
    }

    .id-dropdown {
        position: relative;
        display: inline-block;
    }

    .id-dropdown-content {
        display: none;
        position: absolute;
        background-color: #f6f6f6;
        border: 1px solid #ddd;
        z-index: 1;
        max-height: 20rem;
        overflow-y: scroll;
        left: 10%;
    }

    .id-dropdown-content a {
        color: black;
        padding: 12px 16px;
        text-decoration: none;
        display: block;
    }

    .id-drp-input:hover {
        background-color: #f1f1f1;
    }

    .id-show {
        display: block;
    }

    .id-drp-img {

    }
</style>