<div class="ob-statblock-container ob-resources-holder">
    <div class="ob-rollInfo flexcol ob-resource">
        {{#with (drctx this "Blo") as |ctx|}}
            <div class="ob-roll-holder">
                <img class="ob-roll-icon" src='systems/pmttrpg/assets/damageTypes/Block.png' width='24' height='24'/>
                <p class="ob-rollDisplay">{{ctx.diceCount}}d{{ctx.diceMax}}+{{ctx.dicePower}}</p>
            </div>
        {{/with}}
        {{#with (drctx this "Evd") as |ctx|}}
            <div class="ob-roll-holder">
                <img class="ob-roll-icon" src='systems/pmttrpg/assets/damageTypes/Evade.png' width='24' height='24'/>
                <p class="ob-rollDisplay">{{ctx.diceCount}}d{{ctx.diceMax}}+{{ctx.dicePower}}</p>
            </div>
        {{/with}}
        <div class="ob-type-container">
            <div class="ob-stats-grid">
                {{> "systems/pmttrpg/templates/item/parts/resist-type.hbs" item=system type="Slash" cat=""}}
                {{> "systems/pmttrpg/templates/item/parts/resist-type.hbs" item=system type="Pierce" cat=""}}
                {{> "systems/pmttrpg/templates/item/parts/resist-type.hbs" item=system type="Blunt" cat=""}}
            </div>
        </div>
    </div>

    <div class="ob-clashDescription ob-resource">
        {{{enrichedClashData}}}
    </div>
</div>

<script>
    function toggle(element) {
        document.getElementById(element).classList.toggle("ob-show");
    }
</script>

